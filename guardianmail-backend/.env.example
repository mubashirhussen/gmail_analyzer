# ---- runtime ----
APP_ENV=dev
APP_NAME=GuardianMail AI
APP_VERSION=1.0.0
LOG_LEVEL=INFO
LOG_JSON=true
LOG_TO_FILE=0
REQUEST_MAX_BODY_BYTES=2097152
METRICS_TOKEN=change-me

# ---- security ----
SECRET_KEY=change-me-min-32-chars-cryptographically-random
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30
FERNET_KEY=generate-with-cryptography-fernet-generate-key
PASSWORD_HASH_SCHEME=bcrypt

# ---- persistence ----
MONGO_URI=mongodb://mongo:27017
MONGO_DB=guardianmail
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=5
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=10000

REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=64

# ---- celery ----
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_SOFT_TIME_LIMIT_S=240
CELERY_TASK_TIME_LIMIT_S=300
CELERY_WORKER_PREFETCH_MULTIPLIER=1

# ---- google / ai ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT=http://localhost:8000/api/v1/auth/google/callback
GEMINI_API_KEY=

# ---- threat intel (all optional) ----
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_KEY=
URLSCAN_API_KEY=
PHISHTANK_APP_KEY=
ABUSEIPDB_KEY=
WHOISXML_KEY=

# ---- http ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
TRUSTED_HOSTS=*
WEBHOOK_SECRET=

# ---- rate limits ----
RATE_LIMIT_DEFAULT=120/minute
